# --- web ---
DATABASE_URL=postgres://reelate:CHANGE_ME@reelate-db:5432/reelate
REDIS_URL=redis://reelate-cache:6379
AUTH_SECRET=CHANGE_ME_openssl_rand_hex_32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=https://reelate.co
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_ENABLED=false
STORAGE_ROOT=/data/storage

# --- Object Storage (Hetzner) ---
STORAGE_BACKEND=s3
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=reelate
S3_REGION=fsn1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- worker (config.toml ayrıca: pexels key, redis_host=reelate-cache, enable_redis=true) ---
REELATE_DB_PASSWORD=CHANGE_ME
# --- monitor ---
QUEUE_ALERT_THRESHOLD=5
QUEUE_ALERT_EMAIL=
RESEND_API_KEY=
# ETA hesabı: ortalama render süresi (sn; CPU-limitli prod ölçümü ~270) ve worker sayısı
# (compose'daki worker replicas ile eşle — replicas değişirse bunu da güncelle)
AVG_RENDER_SECONDS=270
WORKER_COUNT=2
